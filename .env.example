AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Required for production-grade encryption. Use a long random value.
MEMORY_ENCRYPTION_SECRET=replace-with-a-long-random-secret

# Walrus Testnet endpoints for hackathon demo.
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# Sui network. Testnet is recommended for the public Walrus publisher demo.
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Tatum is required by the submission rules.
TATUM_API_KEY=
TATUM_BASE_URL=https://api.tatum.io
TATUM_SUI_NETWORK=testnet
