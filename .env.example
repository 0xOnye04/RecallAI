# AI provider: groq or openai. Groq is recommended for free-tier demos.
AI_PROVIDER=groq

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Required for production-grade encryption. Use a long random value.
MEMORY_ENCRYPTION_SECRET=replace-with-a-long-random-secret

# Walrus publisher/aggregator endpoints. Leave blank to use local dev storage.
WALRUS_PUBLISHER_URL=
WALRUS_AGGREGATOR_URL=

# Sui network. Mainnet is preferred for the hackathon requirement.
SUI_NETWORK=mainnet
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
SUI_MEMORY_PACKAGE_ID=
SUI_MEMORY_MODULE=recall_memory
SUI_MEMORY_REGISTRY_ID=

# Tatum is required by the submission rules.
TATUM_API_KEY=
TATUM_BASE_URL=https://api.tatum.io
TATUM_SUI_NETWORK=mainnet
